{
  "expo": {
    "name": "satisfacao-mobile",
    "slug": "satisfacao-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "satisfacaomobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.familiamadalosso.satisfacaomobile",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.familiamadalosso.satisfacaomobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#faab45",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#faab45",
          "dark": {
            "backgroundColor": "#faab45"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "41efc1af-2d97-48f3-8df4-2abe55808086"
      }
    }
  }
}
